{
  "openapi": "3.1.0",
  "info": {
    "title": "KidneyHood Prediction API",
    "version": "2.0.0",
    "description": "Lean Launch MVP API for KidneyHood.org. 5 endpoints: health check, prediction engine, PDF export, Clerk webhook for lead capture, and internal leads list.\n\nKey design decisions:\n- No BFF — frontend calls API directly\n- Auth handled entirely by Clerk (magic link only, 15-min expiry)\n- Lead capture happens inside /predict handler\n- /predict/pdf re-runs engine (stateless) rather than accepting results\n- No guest sessions, no custom rate-limit headers\n- Rate limiting via slowapi middleware on /predict and /webhooks/clerk",
    "contact": {
      "name": "KidneyHood Engineering",
      "email": "engineering@kidneyhood.org"
    },
    "license": {
      "name": "Proprietary"
    }
  },
  "servers": [
    {
      "url": "https://api.kidneyhood.org",
      "description": "Production (Railway)"
    },
    {
      "url": "http://localhost:8000",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "Infrastructure", "description": "Health check for Railway" },
    { "name": "Prediction", "description": "Core prediction engine and PDF export" },
    { "name": "Webhooks", "description": "Clerk auth webhook for lead capture" },
    { "name": "Admin", "description": "Internal admin endpoints" }
  ],
  "x-cors-policy": {
    "allowed_origins": [
      "https://kidneyhood.org",
      "http://localhost:3000"
    ],
    "allowed_methods": ["GET", "POST", "OPTIONS"],
    "allowed_headers": ["Authorization", "Content-Type"],
    "allow_credentials": false,
    "max_age_seconds": 3600
  },
  "paths": {
    "/health": {
      "get": {
        "tags": ["Infrastructure"],
        "operationId": "healthCheck",
        "summary": "Health check for Railway",
        "description": "Returns service status. Used by Railway for zero-downtime deploys and health monitoring.",
        "security": [],
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/HealthResponse" },
                "example": {
                  "status": "ok",
                  "version": "2.0.0"
                }
              }
            }
          }
        }
      }
    },
    "/predict": {
      "post": {
        "tags": ["Prediction"],
        "operationId": "predict",
        "summary": "Run prediction engine",
        "description": "Takes BUN, creatinine, age (and optional name/email for lead capture). Returns 4 trajectory paths (15 time points each), dial_ages per trajectory, and bun_suppression_estimate. Lead is captured in the leads table if name and email are provided.\n\nRate limited via slowapi.",
        "security": [{ "clerkJWT": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PredictRequest" },
              "example": {
                "bun": 35,
                "creatinine": 2.1,
                "age": 58,
                "name": "Jane Doe",
                "email": "jane@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prediction computed successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PredictResponse" },
                "example": {
                  "egfr_baseline": 33.0,
                  "time_points_months": [0, 1, 3, 6, 12, 18, 24, 36, 48, 60, 72, 84, 96, 108, 120],
                  "trajectories": {
                    "no_treatment": [33.0, 32.8, 32.3, 31.7, 30.6, 29.5, 28.4, 26.3, 24.1, 22.0, 19.8, 17.7, 15.5, 13.4, 11.2],
                    "bun_18_24": [33.0, 34.0, 35.7, 36.0, 37.0, 37.6, 37.9, 36.4, 34.9, 33.4, 31.9, 30.4, 28.9, 27.4, 25.9],
                    "bun_13_17": [33.0, 34.6, 36.9, 37.4, 39.4, 40.7, 41.4, 40.4, 39.4, 38.4, 37.4, 36.4, 35.4, 34.4, 33.4],
                    "bun_12": [33.0, 35.4, 38.7, 39.6, 42.6, 44.5, 45.7, 45.2, 44.7, 44.2, 43.7, 43.2, 42.7, 42.2, 41.7]
                  },
                  "dial_ages": {
                    "no_treatment": 68.2,
                    "bun_18_24": null,
                    "bun_13_17": null,
                    "bun_12": null
                  },
                  "bun_suppression_estimate": 7.8
                }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": {
                    "code": "VALIDATION_ERROR",
                    "message": "Invalid request data",
                    "details": [
                      { "field": "bun", "message": "BUN must be between 5 and 150 mg/dL" }
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Clerk JWT"
          },
          "429": {
            "description": "Rate limit exceeded (slowapi)"
          }
        }
      }
    },
    "/predict/pdf": {
      "post": {
        "tags": ["Prediction"],
        "operationId": "predictPdf",
        "summary": "Generate PDF from prediction",
        "description": "Re-runs the prediction engine with the same inputs, renders the chart page via Playwright (headless Chromium), and returns the PDF. Stateless — does not accept pre-computed results.",
        "security": [{ "clerkJWT": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PredictRequest" },
              "example": {
                "bun": 35,
                "creatinine": 2.1,
                "age": 58,
                "name": "Jane Doe",
                "email": "jane@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "PDF generated successfully",
            "content": {
              "application/pdf": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            },
            "headers": {
              "Content-Disposition": {
                "schema": { "type": "string" },
                "example": "attachment; filename=\"kidneyhood-prediction.pdf\""
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Clerk JWT"
          },
          "429": {
            "description": "Rate limit exceeded"
          }
        }
      }
    },
    "/webhooks/clerk": {
      "post": {
        "tags": ["Webhooks"],
        "operationId": "clerkWebhook",
        "summary": "Clerk auth webhook",
        "description": "Receives `user.created` events from Clerk. Extracts email and pipes to the leads table. Verified via Clerk webhook signing secret (svix).",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "description": "Clerk webhook payload (svix-signed). See Clerk docs for full schema."
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Webhook processed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string", "example": "ok" }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid webhook signature or payload"
          }
        }
      }
    },
    "/leads": {
      "get": {
        "tags": ["Admin"],
        "operationId": "listLeads",
        "summary": "List captured leads (admin only)",
        "description": "Returns all leads from the leads table. Internal use only — for manual CSV export to feed email campaigns. Protected by admin API key.",
        "security": [{ "adminApiKey": [] }],
        "responses": {
          "200": {
            "description": "List of leads",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Lead" }
                },
                "example": [
                  {
                    "id": 1,
                    "name": "Jane Doe",
                    "email": "jane@example.com",
                    "bun": 35,
                    "creatinine": 2.1,
                    "age": 58,
                    "created_at": "2026-04-07T14:30:00Z"
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Missing or invalid admin API key"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "clerkJWT": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Clerk-issued JWT from magic link authentication. 15-minute expiry."
      },
      "adminApiKey": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Admin-Key",
        "description": "Server-side admin API key for internal endpoints."
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": { "type": "string", "enum": ["ok"] },
          "version": { "type": "string" }
        }
      },
      "PredictRequest": {
        "type": "object",
        "required": ["bun", "creatinine", "age"],
        "properties": {
          "bun": {
            "type": "number",
            "minimum": 5,
            "maximum": 150,
            "description": "Blood Urea Nitrogen in mg/dL"
          },
          "creatinine": {
            "type": "number",
            "minimum": 0.3,
            "maximum": 15.0,
            "description": "Serum creatinine in mg/dL"
          },
          "age": {
            "type": "integer",
            "minimum": 18,
            "maximum": 100,
            "description": "Patient age in years"
          },
          "name": {
            "type": "string",
            "maxLength": 200,
            "description": "Patient name for lead capture"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Patient email for lead capture (may be pre-filled from Clerk)"
          }
        },
        "description": "Flat object — no oneOf, no arrays. Three required lab fields plus optional lead capture fields."
      },
      "PredictResponse": {
        "type": "object",
        "required": ["egfr_baseline", "time_points_months", "trajectories", "dial_ages", "bun_suppression_estimate"],
        "properties": {
          "egfr_baseline": {
            "type": "number",
            "description": "Starting eGFR computed via CKD-EPI 2021 (race-free, sex-free population average)"
          },
          "time_points_months": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 15,
            "maxItems": 15,
            "description": "Fixed 15-value array: [0, 1, 3, 6, 12, 18, 24, 36, 48, 60, 72, 84, 96, 108, 120]"
          },
          "trajectories": {
            "type": "object",
            "required": ["no_treatment", "bun_18_24", "bun_13_17", "bun_12"],
            "properties": {
              "no_treatment": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 15,
                "maxItems": 15,
                "description": "No-treatment path — linear BUN-adjusted decline"
              },
              "bun_18_24": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 15,
                "maxItems": 15,
                "description": "BUN 18-24 tier treatment path"
              },
              "bun_13_17": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 15,
                "maxItems": 15,
                "description": "BUN 13-17 tier treatment path"
              },
              "bun_12": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 15,
                "maxItems": 15,
                "description": "BUN <=12 tier treatment path"
              }
            }
          },
          "dial_ages": {
            "type": "object",
            "required": ["no_treatment", "bun_18_24", "bun_13_17", "bun_12"],
            "properties": {
              "no_treatment": { "type": ["number", "null"], "description": "Age at which eGFR crosses below 12, or null if no crossing within 10 years" },
              "bun_18_24": { "type": ["number", "null"] },
              "bun_13_17": { "type": ["number", "null"] },
              "bun_12": { "type": ["number", "null"] }
            },
            "description": "Estimated patient age at dialysis (eGFR < 12) per trajectory. null if no crossing within 120 months."
          },
          "bun_suppression_estimate": {
            "type": "number",
            "description": "Current eGFR points suppressed by elevated BUN. Calculated as max(0, (baseline_bun - 10) * 0.31), representing recovery potential if BUN is reduced to optimal range."
          }
        }
      },
      "Lead": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "bun": { "type": "number" },
          "creatinine": { "type": "number" },
          "age": { "type": "integer" },
          "created_at": { "type": "string", "format": "date-time" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string", "enum": ["VALIDATION_ERROR", "AUTH_ERROR", "RATE_LIMIT", "INTERNAL_ERROR"] },
              "message": { "type": "string" },
              "details": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
