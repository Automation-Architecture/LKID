    {"type":"text","id":"tlTitle","x":30,"y":448,"width":600,"height":25,"text":"CRITICAL: The PRD is a SYNTHESIS document, not a parallel draft","fontSize":18,"fontFamily":1,"strokeColor":"#004D43","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"roughness":1,"opacity":100,"angle":0,"seed":49,"version":2,"versionNonce":49,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"CRITICAL: The PRD is a SYNTHESIS document, not a parallel draft","lineHeight":1.25},
    {"type":"text","id":"tlBody","x":30,"y":475,"width":1100,"height":40,"text":"It is created ONLY after Meeting 2 concludes. The PM reads every agent's finalized V2 document\nand produces a single comprehensive document with appendices containing each agent's full V2 work.","fontSize":14,"fontFamily":1,"strokeColor":"#636363","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":2,"roughness":1,"opacity":100,"angle":0,"seed":50,"version":2,"versionNonce":50,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"It is created ONLY after Meeting 2 concludes. The PM reads every agent's finalized V2 document\nand produces a single comprehensive document with appendices containing each agent's full V2 work.","lineHeight":1.25}
